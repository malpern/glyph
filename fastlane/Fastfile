# Glyph deployment lanes. Auth is the App Store Connect API key (no Apple ID / 2FA).
#
#   fastlane setup   # create/ensure the App Store Connect app record (one-time)
#   fastlane beta    # regenerate project, build a signed archive, upload to TestFlight
#
# Credentials are documented in ~/.config/agent/ACCESS.md (Apple section).

default_platform(:ios)

ASC_KEY = {
  key_id: "XQ4565NYZ7",
  issuer_id: "60b8eb46-ca64-4580-a43b-850d92fcc7ab",
  key_filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_XQ4565NYZ7.p8"),
}

TEAM_ID      = "X2RKZ5TG99"
APP_ID       = "dev.malpern.Glyph"
APP_NAME     = "Glyph: Read & Listen"
SCHEME       = "Glyph"
PROJECT      = "Glyph.xcodeproj"

platform :ios do
  before_all do
    ENV["FASTLANE_SKIP_UPDATE_CHECK"] = "1"
    ENV["FASTLANE_HIDE_CHANGELOG"] = "1"
  end

  # App *creation* is the one step Apple does not expose via the API key — it needs
  # an authenticated web session (Apple ID + 2FA). Run `fastlane spaceauth -u <apple-id>`
  # once to mint a ~30-day FASTLANE_SESSION, then this lane works non-interactively.
  # (Or just create the app once in the App Store Connect web UI.)
  desc "Create / ensure the App Store Connect app record (idempotent; needs a Spaceship session)"
  lane :setup do
    produce(
      username: "malpern@gmail.com",
      app_identifier: APP_ID,
      app_name: APP_NAME,
      language: "English",
      sku: "glyph-reader",
      team_id: TEAM_ID
    )
  end

  # Registering the App ID (bundle identifier) on the developer portal IS scriptable
  # with the API key (only the *app record* needs the web session). Registered as
  # UNIVERSAL so a macOS build can share this identifier later.
  desc "Register the App ID / bundle identifier via the ASC API key (idempotent)"
  lane :register_app_id do
    require 'spaceship'
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
      key_id: ASC_KEY[:key_id],
      issuer_id: ASC_KEY[:issuer_id],
      filepath: ASC_KEY[:key_filepath]
    )
    existing = Spaceship::ConnectAPI::BundleId.all.find { |b| b.identifier == APP_ID }
    if existing
      UI.success("Bundle ID already registered: #{APP_ID} (#{existing.id})")
    else
      created = Spaceship::ConnectAPI::BundleId.create(
        name: "Glyph", identifier: APP_ID, platform: "UNIVERSAL"
      )
      UI.success("Registered bundle ID #{APP_ID} (#{created.id})")
    end
  end

  desc "Regenerate the project, build a signed archive, and upload to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(**ASC_KEY)
    sh("cd .. && /opt/homebrew/bin/xcodegen generate")
    build_number = Time.now.strftime("%Y%m%d%H%M")
    # gym/build_app doesn't take the API key directly in this version; pass it to
    # xcodebuild as authentication-key flags so -allowProvisioningUpdates can sign
    # (auto-creating the App Store distribution profile) on both archive and export.
    auth = "-allowProvisioningUpdates " \
           "-authenticationKeyPath #{ASC_KEY[:key_filepath]} " \
           "-authenticationKeyID #{ASC_KEY[:key_id]} " \
           "-authenticationKeyIssuerID #{ASC_KEY[:issuer_id]}"
    build_app(
      project: PROJECT,
      scheme: SCHEME,
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build/ipa",
      export_team_id: TEAM_ID,
      # SWIFT_OPTIMIZATION_LEVEL=-Onone works around a Swift optimizer crash compiling
      # SwiftSoup (a Readium dep) in Release on the current toolchain. Fine for TestFlight;
      # revisit (per-package opt, or a toolchain bump) when chasing release perf.
      # gym auto-injects the API-key auth flags for the *export* step from the
      # app_store_connect_api_key context, so we only pass them for the archive here.
      xcargs: "#{auth} DEVELOPMENT_TEAM=#{TEAM_ID} CURRENT_PROJECT_VERSION=#{build_number} " \
              "SWIFT_OPTIMIZATION_LEVEL=-Onone"
    )
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end

  # Internal testing needs no Apple review. The group is created with access to all
  # builds, so every upload (this one + future) appears automatically once processed.
  # Internal testers must be team members (the account holder already is).
  desc "Show TestFlight groups, their testers, and latest build states"
  lane :tf_status do
    require 'spaceship'
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
      key_id: ASC_KEY[:key_id], issuer_id: ASC_KEY[:issuer_id], filepath: ASC_KEY[:key_filepath]
    )
    app = Spaceship::ConnectAPI::App.find(APP_ID)
    app.get_beta_groups.each do |g|
      UI.message("Group '#{g.name}'  internal=#{g.is_internal_group}  allBuilds=#{g.has_access_to_all_builds}  id=#{g.id}")
      testers = Spaceship::ConnectAPI::BetaTester.all(filter: { "betaGroups" => g.id }) rescue []
      if testers.empty?
        UI.message("   (no testers)")
      else
        testers.each { |t| UI.message("   tester: #{t.email}  state=#{t.beta_tester_state}  installed=#{t.installed_cf_bundle_short_version_string || '—'}") }
      end
    end
    app.get_builds(limit: 3).each { |b| UI.message("Build #{b.version} — #{b.processing_state}") }
  end

  desc "Create an internal TestFlight group and add a tester (idempotent)"
  lane :add_internal_tester do |options|
    require 'spaceship'
    require 'net/http'
    require 'json'
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.create(
      key_id: ASC_KEY[:key_id], issuer_id: ASC_KEY[:issuer_id], filepath: ASC_KEY[:key_filepath]
    )
    email      = options[:email] || "malpern@gmail.com"
    first      = options[:first] || "Micah"
    last       = options[:last]  || "Alpern"
    group_name = options[:group] || "Internal Testers"

    app = Spaceship::ConnectAPI::App.find(APP_ID)
    UI.user_error!("App #{APP_ID} not found") unless app

    group = app.get_beta_groups.find { |g| g.name == group_name }
    if group
      group_id = group.id
      UI.message("Group '#{group_name}' already exists (#{group_id}, internal=#{group.is_internal_group})")
    else
      # fastlane's create_beta_group helper is broken for internal groups (sends
      # publicLinkLimitEnabled, which Apple rejects) — POST directly with valid attrs.
      uri = URI("https://api.appstoreconnect.apple.com/v1/betaGroups")
      req = Net::HTTP::Post.new(uri)
      req["Authorization"] = "Bearer #{Spaceship::ConnectAPI.token.text}"
      req["Content-Type"] = "application/json"
      req.body = { data: {
        type: "betaGroups",
        attributes: { name: group_name, isInternalGroup: true, hasAccessToAllBuilds: true },
        relationships: { app: { data: { type: "apps", id: app.id } } }
      } }.to_json
      res = Net::HTTP.start(uri.host, uri.port, use_ssl: true) { |h| h.request(req) }
      UI.user_error!("Group create failed: #{res.code} #{res.body}") unless res.code.to_i.between?(200, 299)
      group_id = JSON.parse(res.body)["data"]["id"]
      UI.success("Created internal group '#{group_name}' (#{group_id})")
    end

    begin
      Spaceship::ConnectAPI.post_beta_tester_assignment(
        beta_group_ids: [group_id],
        attributes: { email: email, firstName: first, lastName: last }
      )
      UI.success("Added #{email} to '#{group_name}'")
    rescue => e
      # Internal/team members already have a tester record — add it to the group directly.
      tester = Spaceship::ConnectAPI::BetaTester.find(email: email) rescue nil
      if tester
        Spaceship::ConnectAPI.add_beta_tester_to_group(beta_group_id: group_id, beta_tester_ids: [tester.id])
        UI.success("Added existing tester #{email} to '#{group_name}' (id #{tester.id})")
      else
        UI.important("No existing tester for #{email}; original error: #{e.message}")
      end
    end

    app.get_builds(limit: 3).each do |b|
      state = b.respond_to?(:processing_state) ? b.processing_state : "?"
      UI.message("Build #{b.version} — #{state}")
    end rescue nil
  end
end
