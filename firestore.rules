rules_version = '2';

// Real auth (P2.5): a signed-in user may read/write only their own subtree.
// The app authenticates with Firebase Email/Password credentials derived from the
// user's sync key, so `request.auth.uid` is the account the key maps to.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userID}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userID;
    }
  }
}
